generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String
  createdAt DateTime @default(now())
}

model Product {
  id String @id @default(cuid())
  name String
  description String
  price Number
  category String
  imageUrl String
  rating Number
  reviews Number
}

model Order {
  id String @id @default(cuid())
  userId String
  productId String
  quantity Number
  total Number
  status String
  createdAt DateTime @default(now())
}
